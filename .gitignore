# Python caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/

# Test/type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
tests/_*_tmp/
tests/_tmp/
!tests/
!tests/**

# Local environment
.env
.env.*
!.env.example

# Build outputs
build/
dist/
installer/dist/
*.spec.log

# Local databases
*.db
*.sqlite
*.sqlite3

# Runtime files
logs/
log/
backups/
backup/
exports/
export/
temp/
tmp/
downloads/
update-downloads/
update_downloads/
update-temp/
update_tmp/
*.log
*.bak
*.backup

# App runtime folders that may be created during local development
data/*.db
data/*.sqlite
data/*.sqlite3
data/logs/
data/backups/
data/exports/
data/temp/
data/tmp/
data/downloads/
data/update-downloads/

# Source repository folders that must stay trackable
!docs/
!docs/**
!scripts/
!scripts/**
!.github/
!.github/**

# Tooling/local state
.omx/
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db
desktop.ini
